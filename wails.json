{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "upmark",
  "outputfilename": "upmark",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "Brad Webb",
    "email": "ironystock@ironystock.com"
  },
  "info": {
    "companyName": "Captured Ventures",
    "productName": "upmark",
    "productIdentifier": "com.captured-ventures.upmark",
    "description": "A lightweight markdown reader",
    "copyright": "Copyright © 2026 Captured Ventures",
    "comments": "Built with Wails"
  },
  "fileAssociations": [
    {
      "ext": "md",
      "name": "Markdown",
      "description": "Markdown Document",
      "iconName": "fileIcon",
      "role": "Editor"
    },
    {
      "ext": "markdown",
      "name": "Markdown",
      "description": "Markdown Document",
      "iconName": "fileIcon",
      "role": "Editor"
    },
    {
      "ext": "mdown",
      "name": "Markdown",
      "description": "Markdown Document",
      "iconName": "fileIcon",
      "role": "Editor"
    },
    {
      "ext": "mkd",
      "name": "Markdown",
      "description": "Markdown Document",
      "iconName": "fileIcon",
      "role": "Editor"
    }
  ]
}
